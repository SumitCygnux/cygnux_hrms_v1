{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",

    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

    "esModuleInterop": true,

    "strict": true,

    "skipLibCheck": true,

    "outDir": "./dist",
    "rootDir": "./src"
  },

  "include": ["src/**/*"],

  "exclude": ["node_modules"]
}